{
  "name": "dbx-paginated-reporting",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "generate-spec": "curl -sf ${OPENAPI_URL:-http://127.0.0.1:8000/openapi.json} -o openapi.json",
    "generate-all": "npm run generate-spec && orval"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tanstack/vue-query": "^5.92.9",
    "audit": "^0.0.6",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^4.4.7",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.1",
    "fix": "^0.0.3",
    "js-beautify": "^1.14.8",
    "mustache": "^4.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/mustache": "^4.2.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "axios": "^1.13.5",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "orval": "^7.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.11",
    "vue-tsc": "^2.2.0"
  }
}
